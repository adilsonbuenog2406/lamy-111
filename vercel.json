{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run verify:vercel-output",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/calculator-leads.js": {
      "maxDuration": 10
    },
    "api/leads.js": {
      "maxDuration": 10
    },
    "api/health.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|svg|mp4|webm|ico|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/api/index.js"
    },
    {
      "source": "/index.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/artigos.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/calculadora.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/artigos/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/:slug",
      "destination": "/api/index.js"
    }
  ]
}
